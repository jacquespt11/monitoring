generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reseau {
  id     Int      @id @default(autoincrement())
  nom    String
  ip     String String
  statut String @default("Inconnu")
  temps  String? @default("N/A")
  test   String @default("Jamais testé")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
